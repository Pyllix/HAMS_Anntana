// status model

model AssetStatus {
    id        Int       @id @default(autoincrement()) @map("status_id")
    code      String    @unique @default("") @map("code") @db.VarChar(20)
    name      String    @default("") @map("name") @db.VarChar(255)
    createdAt DateTime  @default(now()) @map("created_at")
    updatedAt DateTime  @updatedAt @map("updated_at")
    deletedAt DateTime? @map("deleted_at")

    @@map("asset_status")
}

model AvailabilityStatus {
    id        Int       @id @default(autoincrement()) @map("availability_status_id")
    code      String    @unique @default("") @map("code") @db.VarChar(20)
    name      String    @default("") @map("name") @db.VarChar(255)
    createdAt DateTime  @default(now()) @map("created_at")
    updatedAt DateTime  @updatedAt @map("updated_at")
    deletedAt DateTime? @map("deleted_at")

    @@map("availability_status")
}
